@model LaconicAndIconic.Web.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Новий пароль";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-collage">
            @for (var i = 1; i <= 6; i++)
            {
                <img src="~/images/login/food-@(i).jpg" alt=""
                     onerror="this.outerHTML='<div class=placeholder-cell></div>'"/>
            }
        </div>

        <div class="auth-form">
            <h1>Новий пароль</h1>
            <p class="subtitle">Введіть новий пароль для вашого акаунту</p>

            <form asp-action="ResetPassword" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-errors">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <input type="hidden" asp-for="Token"/>
                <input type="hidden" asp-for="Email"/>

                <div class="input-field">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input asp-for="Password" type="password" id="pw" placeholder="Новий пароль" autocomplete="new-password"/>
                    <button type="button" class="pw-toggle" onclick="var p=document.getElementById('pw');p.type=p.type==='password'?'text':'password'">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="input-field">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input asp-for="ConfirmPassword" type="password" id="cpw" placeholder="Підтвердити пароль" autocomplete="new-password"/>
                    <button type="button" class="pw-toggle" onclick="var p=document.getElementById('cpw');p.type=p.type==='password'?'text':'password'">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>

                <button type="submit" class="ck-btn ck-btn-block">Скинути пароль</button>
            </form>

            <div class="auth-alt">
                <a asp-controller="Account" asp-action="Login">Повернутися до входу</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
