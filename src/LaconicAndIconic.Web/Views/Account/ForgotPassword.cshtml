@model LaconicAndIconic.Web.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Забули пароль";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-collage">
            @for (var i = 1; i <= 6; i++)
            {
                <img src="~/images/login/food-@(i).jpg" alt=""
                     onerror="this.outerHTML='<div class=placeholder-cell></div>'"/>
            }
        </div>

        <div class="auth-form">
            <h1>Скидання пароля</h1>
            <p class="subtitle">Введіть email, щоб отримати посилання для скидання пароля</p>

            <form asp-action="ForgotPassword" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-errors">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="input-field">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="20" height="16" x="2" y="4" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                    <input asp-for="Email" placeholder="Email" autocomplete="email"/>
                    <span asp-validation-for="Email"></span>
                </div>

                <button type="submit" class="ck-btn ck-btn-block">Надіслати посилання</button>
            </form>

            <div class="auth-alt">
                Згадали пароль?
                <a asp-controller="Account" asp-action="Login">Увійти</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
