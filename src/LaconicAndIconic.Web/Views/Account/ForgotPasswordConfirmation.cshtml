@{
    ViewData["Title"] = "Підтвердження скидання";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-collage">
            @for (var i = 1; i <= 6; i++)
            {
                <img src="~/images/login/food-@(i).jpg" alt=""
                     onerror="this.outerHTML='<div class=placeholder-cell></div>'"/>
            }
        </div>

        <div class="auth-form">
            <h1>Перевірте пошту</h1>
            <p class="subtitle">Якщо акаунт з таким email існує, ми надіслали посилання для скидання пароля.</p>

            @if (TempData["ResetLink"] is string resetLink)
            {
                <div class="auth-errors" style="background: #e8f5e9; border-color: #a5d6a7; color: #2e7d32;">
                    <p style="margin: 0 0 6px; font-weight: 600;">Посилання для скидання (тільки для розробки):</p>
                    <a href="@resetLink" style="word-break: break-all; color: #2e7d32;">@resetLink</a>
                </div>
            }

            <div class="auth-alt">
                <a asp-controller="Account" asp-action="Login">Повернутися до входу</a>
            </div>
        </div>
    </div>
</div>
