@{
    ViewData["Title"] = "Пароль скинуто";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-collage">
            @for (var i = 1; i <= 6; i++)
            {
                <img src="~/images/login/food-@(i).jpg" alt=""
                     onerror="this.outerHTML='<div class=placeholder-cell></div>'"/>
            }
        </div>

        <div class="auth-form">
            <h1>Пароль скинуто</h1>
            <p class="subtitle">Ваш пароль було успішно змінено. Тепер ви можете увійти з новим паролем.</p>

            <a asp-controller="Account" asp-action="Login" class="ck-btn ck-btn-block" style="text-align: center; text-decoration: none;">
                Увійти
            </a>
        </div>
    </div>
</div>
