@model LaconicAndIconic.Web.Models.AdminUsersViewModel

@{
    ViewData["Title"] = "Управління користувачами";
}

<div style="background: var(--ck-bg); min-height: 100vh; padding: 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
        <div style="margin-bottom: 24px;">
            <a asp-action="Index" style="display: inline-block; color: var(--ck-orange); text-decoration: none; font-weight: 600; transition: color 0.3s;">
                ← Назад до меню
            </a>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h1 style="color: var(--ck-text); font-size: 1.8rem; margin: 0;">Управління користувачами</h1>
            <span style="background: var(--ck-orange); color: white; padding: 8px 16px; border-radius: var(--ck-radius-pill); font-weight: 600;">@Model.Users.Count користувачів</span>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div style="background: #E8F5E9; border-left: 4px solid #4CAF50; padding: 16px; border-radius: var(--ck-radius); margin-bottom: 20px; color: #2E7D32;">
                <strong>✓</strong> @successMessage
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div style="background: var(--ck-error-bg); border-left: 4px solid var(--ck-error); padding: 16px; border-radius: var(--ck-radius); margin-bottom: 20px; color: var(--ck-error);">
                <strong>✕</strong> @errorMessage
            </div>
        }

        @if (Model.Users.Count > 0)
        {
            <div style="background: var(--ck-white); border-radius: var(--ck-radius-lg); overflow: hidden; box-shadow: 0 2px 8px rgba(60, 40, 20, 0.06);">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--ck-input-bg); border-bottom: 1px solid var(--ck-border);">
                            <th style="padding: 16px; text-align: left; color: var(--ck-text); font-weight: 600; font-size: 0.95rem;">ID</th>
                            <th style="padding: 16px; text-align: left; color: var(--ck-text); font-weight: 600; font-size: 0.95rem;">Користувач</th>
                            <th style="padding: 16px; text-align: left; color: var(--ck-text); font-weight: 600; font-size: 0.95rem;">Email</th>
                            <th style="padding: 16px; text-align: center; color: var(--ck-text); font-weight: 600; font-size: 0.95rem;">Фоловери</th>
                            <th style="padding: 16px; text-align: center; color: var(--ck-text); font-weight: 600; font-size: 0.95rem;">Підписки</th>
                            <th style="padding: 16px; text-align: right; color: var(--ck-text); font-weight: 600; font-size: 0.95rem;">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr style="border-bottom: 1px solid var(--ck-border); transition: background 0.2s;">
                                <td style="padding: 16px; color: var(--ck-text-muted);">@user.Id</td>
                                <td style="padding: 16px;">
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        @if (!string.IsNullOrEmpty(user.ProfilePicturePath))
                                        {
                                            <img src="@user.ProfilePicturePath" alt="@user.UserName" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--ck-orange); display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-user" style="color: white; font-size: 0.9rem;"></i>
                                            </div>
                                        }
                                        <span style="color: var(--ck-text); font-weight: 500;">@user.UserName</span>
                                    </div>
                                </td>
                                <td style="padding: 16px; color: var(--ck-text-muted); font-size: 0.9rem;">@user.Email</td>
                                <td style="padding: 16px; text-align: center;">
                                    <span style="background: rgba(232, 145, 58, 0.1); color: var(--ck-orange); padding: 6px 12px; border-radius: var(--ck-radius-pill); font-weight: 600; display: inline-block; font-size: 0.85rem;">@user.FollowerCount</span>
                                </td>
                                <td style="padding: 16px; text-align: center;">
                                    <span style="background: rgba(232, 145, 58, 0.1); color: var(--ck-orange); padding: 6px 12px; border-radius: var(--ck-radius-pill); font-weight: 600; display: inline-block; font-size: 0.85rem;">@user.FollowingCount</span>
                                </td>
                                <td style="padding: 16px; text-align: right;">
                                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                        <a asp-controller="User" asp-action="Profile" asp-route-id="@user.Id" style="padding: 8px 14px; background: var(--ck-orange); color: white; border: none; border-radius: var(--ck-radius); text-decoration: none; font-weight: 600; cursor: pointer; transition: background 0.3s; display: inline-block; font-size: 0.85rem;">
                                            <i class="fas fa-eye"></i> Переглянути
                                        </a>
                                        <form asp-action="DeleteUser" method="post" style="display: inline;" onsubmit="return confirm('Ви впевнені, що хочете видалити цього користувача?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" style="padding: 8px 14px; background: var(--ck-error); color: white; border: none; border-radius: var(--ck-radius); font-weight: 600; cursor: pointer; transition: background 0.3s; font-size: 0.85rem;">
                                                <i class="fas fa-trash"></i> Видалити
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="background: var(--ck-white); border-radius: var(--ck-radius-lg); padding: 32px; text-align: center; box-shadow: 0 2px 8px rgba(60, 40, 20, 0.06);">
                <i class="fas fa-info-circle" style="font-size: 2.5rem; color: var(--ck-text-muted); margin-bottom: 16px; display: block;"></i>
                <p style="color: var(--ck-text-muted); font-size: 0.95rem;">Немає користувачів в системі.</p>
            </div>
        }
    </div>
</div>

<style>
    button:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
    
    a:hover {
        color: var(--ck-orange-hover) !important;
        opacity: 0.9;
        transform: translateY(-1px);
    }
    
    tr:hover {
        background: var(--ck-input-bg) !important;
    }
</style>
