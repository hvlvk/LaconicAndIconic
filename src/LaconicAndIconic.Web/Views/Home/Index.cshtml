@model RecipeListViewModel
@{
    ViewData["Title"] = "Recipes";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="home-search-panels">
    <form asp-controller="Home" asp-action="Index" method="get" class="home-search-form">
        <label for="localSearch">Пошук у нашій базі</label>
        <div>
            <input id="localSearch" type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Назва, категорія або опис" />
            <button type="submit" class="ck-btn ck-btn-sm">Шукати</button>
        </div>
    </form>

    <form asp-controller="Home" asp-action="Index" method="get" class="home-search-form">
        <label for="externalSearch">Пошук у TheMealDB</label>
        <div>
            <input id="externalSearch" type="search" name="externalSearchTerm" value="@Model.ExternalSearchTerm" placeholder="Наприклад: chicken" />
            <button type="submit" class="ck-btn ck-btn-sm">Шукати</button>
        </div>
    </form>
</div>

<h2 class="home-external-title">Рецепти з бази</h2>
<div class="recipe-grid">
    @if (Model.Recipes.Count == 0)
    {
        <p class="home-empty-results">Рецептів не знайдено. Спробуйте змінити пошук або фільтри.</p>
    }
    else
    {
        @foreach (var recipe in Model.Recipes)
        {
                <div class="recipe-card">
                <div class="recipe-image">
                    <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id" class="home-recipe-link">
                        @if (!string.IsNullOrEmpty(recipe.ImagePath))
                        {
                            <img src="@recipe.ImagePath" alt="@recipe.Title">
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=300&h=200&fit=crop" alt="Placeholder">
                        }
                    </a>
                </div>
                <div class="recipe-details">
                    <h3 class="recipe-title">
                        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id" class="home-recipe-link">@recipe.Title</a>
                    </h3>
                    <div class="recipe-meta">
                        <span class="recipe-rating">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                            @recipe.AverageRating.ToString("0.0")
                        </span>
                        <span class="recipe-author">@($"@{recipe.AuthorName}")</span>
                    </div>
                </div>
                </div>
        }
    }
</div>

@if (Model.ExternalRecipes.Count > 0)
{
    <h2 class="home-external-title">Рецепти з TheMealDB</h2>
    <div class="recipe-grid">
        @foreach (var recipe in Model.ExternalRecipes)
        {
            <div class="recipe-card">
                <div class="recipe-image">
                    <a asp-controller="ExternalRecipes" asp-action="Details" asp-route-externalId="@recipe.ExternalId" class="home-recipe-link">
                        @if (!string.IsNullOrEmpty(recipe.ImagePath))
                        {
                            <img src="@recipe.ImagePath" alt="@recipe.Title">
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=300&h=200&fit=crop" alt="Placeholder">
                        }
                    </a>
                </div>
                <div class="recipe-details">
                    <h3 class="recipe-title">
                        <a asp-controller="ExternalRecipes" asp-action="Details" asp-route-externalId="@recipe.ExternalId" class="home-recipe-link">@recipe.Title</a>
                    </h3>
                    <div class="recipe-meta">
                        <span class="recipe-author">@recipe.AuthorName</span>
                        <span class="recipe-author">@recipe.CategoryName</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <div class="home-pagination">
        @if (Model.HasPreviousPage)
        {
            <a asp-controller="Home" asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-externalSearchTerm="@Model.ExternalSearchTerm"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-sortBy="@Model.SortBy"
               asp-route-pageNumber="@(Model.PageNumber - 1)"
               class="home-pagination-link">
                Previous
            </a>
        }
        else
        {
            <button class="home-pagination-disabled" disabled>
                Previous
            </button>
        }

        <span class="home-pagination-current">
            Page @Model.PageNumber of @Model.TotalPages
        </span>

        @if (Model.HasNextPage)
        {
            <a asp-controller="Home" asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-externalSearchTerm="@Model.ExternalSearchTerm"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-sortBy="@Model.SortBy"
               asp-route-pageNumber="@(Model.PageNumber + 1)"
               class="home-pagination-link">
                Next
            </a>
        }
        else
        {
            <button class="home-pagination-disabled" disabled>
                Next
            </button>
        }
    </div>
}
