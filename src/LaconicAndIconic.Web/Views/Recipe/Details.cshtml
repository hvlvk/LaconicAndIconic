@model LaconicAndIconic.Web.Models.RecipeDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}


<div class="recipe-page">
    <section class="recipe-main">
        <div>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.Title" class="recipe-photo" />
            }
            else
            {
                <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=800&h=500&fit=crop" alt="Recipe image" class="recipe-photo" />
            }
        </div>

        <div>
            <div class="recipe-title-row">
                <h1>@Model.Title</h1>
                <div class="recipe-owner-actions">
                    @if (User.Identity?.IsAuthenticated == true && User.GetUserId() == Model.AuthorId)
                    {
                        <a asp-controller="Recipe" asp-action="Edit" asp-route-id="@Model.Id" class="recipe-save" title="Edit recipe">
                            Редагувати
                        </a>
                    }

                    <a href="#" class="recipe-save" title="Save recipe">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="recipe-save-icon">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                        Зберегти
                    </a>
                </div>
            </div>

            <div class="recipe-meta">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="recipe-meta-icon">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                    </svg>
                    @Model.PrepTimeMin хв
                </span>
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="recipe-meta-icon">
                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.64 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                    @Model.Servings порції
                </span>
            </div>

            <div class="recipe-author-row">
                @if (!string.IsNullOrEmpty(Model.AuthorProfilePicturePath))
                {
                    <img src="@Model.AuthorProfilePicturePath" alt="@Model.AuthorName" class="recipe-author-avatar recipe-author-avatar--image" />
                }
                else
                {
                    <span class="recipe-author-avatar">@(Model.AuthorName.Length > 0 ? Model.AuthorName.Substring(0, 1).ToUpper() : "U")</span>
                }
                <a asp-controller="User" asp-action="Profile" asp-route-id="@Model.AuthorId" class="recipe-author-link">@($"@{Model.AuthorName}")</a>

                @if (User.Identity?.IsAuthenticated == true && User.GetUserId() != Model.AuthorId)
                {
                    if (Model.IsSubscribedToAuthor)
                    {
                        <form asp-controller="User" asp-action="Unsubscribe" asp-route-id="@Model.AuthorId" method="post" class="d-inline">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="recipe-follow recipe-follow--unsubscribe">Відписатись</button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="User" asp-action="Subscribe" asp-route-id="@Model.AuthorId" method="post" class="d-inline">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="recipe-follow">Підписатись</button>
                        </form>
                    }
                }
            </div>

            <div class="recipe-rating-panel">
                <div class="recipe-rating-summary">
                    <span class="recipe-rating-score">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        @Model.AverageRating.ToString("0.0")
                    </span>
                    <span class="recipe-rating-count">(@Model.RatingCount оцінок)</span>
                    @if (Model.CurrentUserRating.HasValue)
                    {
                        <span class="recipe-rating-current">Ваша оцінка: @Model.CurrentUserRating</span>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Recipe" asp-action="Rate" asp-route-id="@Model.Id" method="post" class="recipe-rate-form">
                        <span class="recipe-rate-label">Оцініть рецепт:</span>
                        <div class="recipe-rate-stars">
                            @for (var score = 1; score <= 5; score++)
                            {
                                var isActive = Model.CurrentUserRating.HasValue && Model.CurrentUserRating.Value >= score;
                                <button type="submit" name="score" value="@score" class="recipe-rate-star @(isActive ? "recipe-rate-star--active" : string.Empty)" aria-label="Поставити @score зірок" title="@score зірок">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="@(isActive ? "recipe-rate-star-icon--active" : string.Empty)">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                    </svg>
                                </button>
                            }
                        </div>
                    </form>
                }
                else
                {
                    <div class="recipe-rate-note">Увійдіть, щоб поставити оцінку.</div>
                }
            </div>

            <p class="recipe-desc">@Model.Description</p>
        </div>
    </section>

    <section class="recipe-sections">
        <div>
            <h2>
                Інградієнти
            </h2>
            <ul class="ingredients-list">
                @foreach (var ingredient in string.IsNullOrWhiteSpace(Model.Ingredients) ? Array.Empty<string>() : Model.Ingredients.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <li><input type="checkbox" /> @ingredient</li>
                }
            </ul>
        </div>

        <div>
            <h2>
                Спосіб приготування
            </h2>
            <ol class="steps-list">
                @foreach (var step in string.IsNullOrWhiteSpace(Model.CookingMethod) ? Array.Empty<string>() : Model.CookingMethod.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <li>@step</li>
                }
            </ol>
        </div>
    </section>

    <section class="recipe-comments">
        <h2 class="recipe-comments-title">
            Коментарі
        </h2>
        <form class="comment-form">
            <input type="text" placeholder="Поділіться з іншими як вам смакувало..." />
            <button type="button" title="Send comment">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="comment-send-icon">
                    <path d="M16.6915026,12.4744748 L3.50612381,13.2599618 C3.19218622,13.2599618 3.03521743,13.4170592 3.03521743,13.5741566 L1.15159189,20.0151496 C0.8376543,20.8006365 0.99,21.89 1.77946707,22.52 C2.41,22.99 3.50612381,23.1 4.13399899,22.8429026 L21.714504,14.0454487 C22.6563168,13.5741566 23.1272231,12.6315722 22.9702544,11.6889879 L4.13399899,1.16346272 C3.34915502,0.9 2.40734225,1.00636533 1.77946707,1.4776575 C0.994623095,2.10604706 0.837654326,3.0486314 1.15159189,3.99701575 L3.03521743,10.4380088 C3.03521743,10.5951061 3.34915502,10.7521035 3.50612381,10.7521035 L16.6915026,11.5375905 C16.6915026,11.5375905 17.1624089,11.5375905 17.1624089,12.0088827 C17.1624089,12.4744748 16.6915026,12.4744748 16.6915026,12.4744748 Z"/>
                </svg>
                Надіслати
            </button>
        </form>
    </section>
</div>

