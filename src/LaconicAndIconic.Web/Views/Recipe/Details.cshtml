@model LaconicAndIconic.Web.Models.RecipeDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<style>
    .recipe-page {
        max-width: 1080px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid #e6e0d9;
    }

    .recipe-main {
        display: grid;
        grid-template-columns: 48% 52%;
        gap: 1.5rem;
        padding: 1.5rem;
        border-bottom: 1px solid #ece8e2;
    }

    .recipe-photo {
        width: 100%;
        height: 240px;
        object-fit: cover;
        border-radius: 2px;
    }

    .recipe-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.5rem;
        padding-right: 1.5rem;
    }

    .recipe-title-row h1 {
        margin: 0;
        font-size: 1.9rem;
        line-height: 1.1;
    }

    .recipe-save {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid #d8d2ca;
        border-radius: 10px;
        background: #f8f6f3;
        padding: 0.4rem 0.7rem;
        margin: auto;
        font-weight: 600;
        color: #2f2f2f;
        text-decoration: none;
        transition: background-color 0.15s, border-color 0.15s, color 0.15s;
    }

    .recipe-save:hover {
        color: var(--ck-orange);
        border-color: var(--ck-orange);
    }

    .recipe-meta {
        display: flex;
        align-items: center;
        gap: 1.4rem;
        font-size: 1rem;
        margin: 0.8rem 0 1rem;
        color: #2f2f2f;
        font-weight: 600;
    }

    .recipe-meta span {
        display: inline-flex;
        align-items: center;
    }

    .recipe-author-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1rem;
    }

    .recipe-author-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 2px solid #1f1f1f;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 700;
        color: #444;
    }

    .recipe-follow {
        border: 0;
        background: #e3953f;
        color: #fff;
        font-weight: 700;
        padding: 0.42rem 0.9rem;
        border-radius: 10px;
        cursor: pointer;
        margin-left: 1.2rem;
    }

    .recipe-desc {
        margin: 0;
        color: #494949;
        line-height: 1.55;
        white-space: pre-line;
    }

    .recipe-sections {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        padding: 1.1rem 1.5rem 1.5rem;
        border-bottom: 1px solid #ece8e2;

        .recipe-save svg {
            color: #e3953f;
        }
    }

    .recipe-sections h2 {
        margin-top: 0;
        margin-bottom: 0.8rem;
        font-size: 1.85rem;
    }

    .recipe-sections h2 {
        display: inline-flex;
        align-items: center;
        color: #2f2f2f;
    }

    .recipe-sections h2 svg {
        color: #e3953f;
    }

    .recipe-comments h2 {
        display: inline-flex;
        align-items: center;
        color: #2f2f2f;
    }

    .recipe-comments h2 svg {
        color: #e3953f;
    }

    .comment-form button svg {
        color: currentColor;
    }

    .ingredients-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ingredients-list li {
        margin: 0.75rem 0;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .steps-list {
        margin: 0;
        padding-left: 1.2rem;
    }

    .steps-list li {
        margin-bottom: 0.95rem;
        line-height: 1.45;
    }

    .recipe-comments {
        padding: 1rem 1.5rem 1.5rem;
    }

    .comment-form {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.8rem;
        max-width: 560px;
    }

    .comment-form input {
        border: 1px solid #dbd6d0;
        border-radius: 3px;
        padding: 0.6rem 0.7rem;
    }

    .comment-form button {
        border: 0;
        border-radius: var(--ck-radius);
        background: #e3953f;
        color: #fff;
        font-weight: 700;
        padding: 0.2rem 0.8rem
    }

    @@media (max-width: 900px) {
        .recipe-main,
        .recipe-sections {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="recipe-page">
    <section class="recipe-main">
        <div>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.Title" class="recipe-photo"/>
            }
            else
            {
                <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=800&h=500&fit=crop"
                     alt="Recipe image" class="recipe-photo"/>
            }
        </div>

        <div>
            <div class="recipe-title-row">
                <h1>@Model.Title</h1>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (Model.IsFavorited)
                    {
                        <form asp-controller="Favorites" asp-action="Remove" method="post" style="margin: 0;">
                            <input type="hidden" name="recipeId" value="@Model.Id"/>
                            <button type="submit" class="recipe-save"
                                    style="cursor: pointer; background: #fff3e8; border-color: var(--ck-orange); color: var(--ck-orange);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                     stroke="currentColor" stroke-width="2"
                                     style="width: 16px; height: 16px; color: var(--ck-orange);">
                                    <path
                                        d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                                Збережено
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Favorites" asp-action="Add" method="post" style="margin: 0;">
                            <input type="hidden" name="recipeId" value="@Model.Id"/>
                            <button type="submit" class="recipe-save" style="cursor: pointer;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;">
                                    <path
                                        d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                                Зберегти
                            </button>
                        </form>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="recipe-save" title="Log in to save">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" style="width: 16px; height: 16px;">
                            <path
                                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                        Зберегти
                    </a>
                }
            </div>

            <div class="recipe-meta">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                         style="width: 18px; height: 18px; display: inline; margin-right: 0.3rem; color: #f4a500;">
                        <path
                            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    4.7
                </span>
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                         style="width: 18px; height: 18px; display: inline; margin-right: 0.3rem;">
                        <path
                            d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                    </svg>
                    @Model.PrepTimeMin хв
                </span>
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                         style="width: 18px; height: 18px; display: inline; margin-right: 0.3rem;">
                        <path
                            d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.64 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                    4 персони
                </span>
            </div>

            <div class="recipe-author-row">
                <span class="recipe-author-avatar">up</span>
                <a asp-controller="User" asp-action="Profile" asp-route-id="@Model.AuthorId"
                   style="color: #4d4d4d; text-decoration: none;">@($"@{Model.AuthorName}")</a>
                <button type="button" class="recipe-follow">Підписатись</button>
            </div>

            <p class="recipe-desc">@Model.Description</p>
        </div>
    </section>

    <section class="recipe-sections">
        <div>
            <h2>
                Інградієнти
            </h2>
            <ul class="ingredients-list">
                <li><input type="checkbox"/> 200 гр спагетті</li>
                <li><input type="checkbox"/> 50 гр пармезану</li>
                <li><input type="checkbox"/> 2 зубчики часнику</li>
            </ul>
        </div>

        <div>
            <h2>
                Спосіб приготування
            </h2>
            <ol class="steps-list">
                <li>Закипʼятіть 1.5 літри води і посоліть. Варіть згідно часу на упаковці.</li>
                <li>У сковорідці розігрійте оливкову олію, додайте нарізаний часник і обсмажте 30 секунд.</li>
                <li>Додайте нарізану соломкою шинку і готуйте 3 хв.</li>
                <li>Додайте зварену пасту і ретельно перемішайте.</li>
            </ol>
        </div>
    </section>

    <section class="recipe-comments">
        <h2 style="margin: 0 0 0.8rem; font-size: 1.7rem;">
            Коментарі
        </h2>
        <form class="comment-form">
            <input type="text" placeholder="Поділіться з іншими як вам смакувало..."/>
            <button type="button" title="Send comment">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                     style="width: 18px; height: 18px; display: inline; margin-right: 0.3rem;">
                    <path
                        d="M16.6915026,12.4744748 L3.50612381,13.2599618 C3.19218622,13.2599618 3.03521743,13.4170592 3.03521743,13.5741566 L1.15159189,20.0151496 C0.8376543,20.8006365 0.99,21.89 1.77946707,22.52 C2.41,22.99 3.50612381,23.1 4.13399899,22.8429026 L21.714504,14.0454487 C22.6563168,13.5741566 23.1272231,12.6315722 22.9702544,11.6889879 L4.13399899,1.16346272 C3.34915502,0.9 2.40734225,1.00636533 1.77946707,1.4776575 C0.994623095,2.10604706 0.837654326,3.0486314 1.15159189,3.99701575 L3.03521743,10.4380088 C3.03521743,10.5951061 3.34915502,10.7521035 3.50612381,10.7521035 L16.6915026,11.5375905 C16.6915026,11.5375905 17.1624089,11.5375905 17.1624089,12.0088827 C17.1624089,12.4744748 16.6915026,12.4744748 16.6915026,12.4744748 Z"/>
                </svg>
                Надіслати
            </button>
        </form>
    </section>
</div>

