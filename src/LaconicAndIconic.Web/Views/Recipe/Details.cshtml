@model LaconicAndIconic.Web.Models.RecipeDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<style>
    .recipe-page {
        max-width: 1080px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid #e6e0d9;
    }

    .recipe-main {
        display: grid;
        grid-template-columns: 48% 52%;
        gap: 1.5rem;
        padding: 1.5rem;
        border-bottom: 1px solid #ece8e2;
    }

    .recipe-photo {
        width: 100%;
        height: 240px;
        object-fit: cover;
        border-radius: 2px;
    }

    .recipe-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.5rem;
        padding-right: 1.5rem;
    }

    .recipe-title-row h1 {
        margin: 0;
        font-size: 1.9rem;
        line-height: 1.1;
    }

    .recipe-save {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid #d8d2ca;
        border-radius: 10px;
        background: #f8f6f3;
        padding: 0.4rem 0.7rem;
        margin: auto;
        font-weight: 600;
        color: #2f2f2f;
        text-decoration: none;
        transition: background-color 0.15s, border-color 0.15s, color 0.15s;
    }

    .recipe-save:hover {
        color: var(--ck-orange);
        border-color: var(--ck-orange);
    }

    .recipe-report-btn {
        border-color: #82403e;
        background: #82403e;
        color: #fff;
    }

    .recipe-report-btn:hover {
        background: #82403e;
        border-color: #82403e;
    }

    .recipe-meta {
        display: flex;
        align-items: center;
        gap: 1.4rem;
        font-size: 1rem;
        margin: 0.8rem 0 1rem;
        color: #2f2f2f;
        font-weight: 600;
    }

    .recipe-meta span {
        display: inline-flex;
        align-items: center;
    }

    .recipe-author-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1rem;
    }

    .recipe-author-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 2px solid #1f1f1f;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 700;
        color: #444;
    }

    .recipe-follow {
        border: 0;
        background: #e3953f;
        color: #fff;
        font-weight: 700;
        padding: 0.42rem 0.9rem;
        border-radius: 10px;
        cursor: pointer;
        margin-left: 1.2rem;
    }

    .recipe-desc {
        margin: 0;
        color: #494949;
        line-height: 1.55;
        white-space: pre-line;
    }

    .recipe-sections {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        padding: 1.1rem 1.5rem 1.5rem;
        border-bottom: 1px solid #ece8e2;

    .recipe-save svg {
        color: #e3953f;
    }
    }

    .recipe-sections h2 {
        margin-top: 0;
        margin-bottom: 0.8rem;
        font-size: 1.85rem;
    }

    .recipe-sections h2 {
        display: inline-flex;
        align-items: center;
        color: #2f2f2f;
    }

    .recipe-sections h2 svg {
        color: #e3953f;
    }

    .recipe-comments h2 {
        display: inline-flex;
        align-items: center;
        color: #2f2f2f;
    }

    .recipe-comments h2 svg {
        color: #e3953f;
    }

    .comment-form button svg {
        color: currentColor;
    }

    .ingredients-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ingredients-list li {
        margin: 0.75rem 0;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .steps-list {
        margin: 0;
        padding-left: 1.2rem;
    }

    .steps-list li {
        margin-bottom: 0.95rem;
        line-height: 1.45;
    }

    .recipe-comments {
        padding: 1rem 1.5rem 1.5rem;
    }

    .comment-form {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.8rem;
        max-width: 560px;
    }

    .comment-form input {
        border: 1px solid #dbd6d0;
        border-radius: 3px;
        padding: 0.6rem 0.7rem;
    }

    .comment-form button {
        border: 0;
        border-radius: var(--ck-radius);
        background: #e3953f;
        color: #fff;
        font-weight: 700;
        padding: 0.2rem 0.8rem
    }

    .comments-list {
        margin-top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .comment-item {
        background: #fdfbf9;
        border: 1px solid #efeae4;
        border-radius: 4px;
        padding: 1rem;
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .comment-author {
        font-weight: 700;
        color: #2f2f2f;
    }

    .comment-date {
        color: #888;
        font-size: 0.85rem;
    }

    .comment-content {
        line-height: 1.4;
        color: #444;
        margin: 0;
        white-space: pre-wrap;
    }

    .comment-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.75rem;
    }

    .comment-like-form {
        margin: 0;
    }

    .comment-like {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid #e1d8ce;
        border-radius: var(--ck-radius);
        background: #fff;
        color: #6c6258;
        font-weight: 700;
        padding: 0.25rem 0.55rem;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s, background-color 0.15s;
    }

    .comment-like:hover,
    .comment-like--active {
        border-color: #e3953f;
        background: #fff7ee;
        color: #e3953f;
    }

    .comment-like[disabled] {
        cursor: default;
        opacity: 0.75;
    }

    .comment-delete {
        background: none;
        border: none;
        color: #aaa;
        font-size: 0.8rem;
        cursor: pointer;
        padding: 0;
        transition: color 0.15s;
    }

    .comment-delete:hover {
        color: #c0392b;
    }

    .comment-edit-btn {
        background: none;
        border: none;
        color: #aaa;
        font-size: 0.9rem;
        cursor: pointer;
        padding: 0;
        transition: color 0.15s;
    }

    .comment-edit-btn:hover {
        color: #e3953f;
    }

    .comment-edit-input {
        width: 100%;
        border: 1px solid #dbd6d0;
        border-radius: 3px;
        padding: 0.6rem;
        margin-bottom: 0.5rem;
        font-family: inherit;
        resize: vertical;
        min-height: 60px;
    }

    .comment-edit-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
    }

    .comment-save-btn {
        border: 0;
        border-radius: var(--ck-radius);
        background: #e3953f;
        color: #fff;
        font-weight: 700;
        padding: 0.3rem 0.8rem;
        cursor: pointer;
    }

    .comment-cancel-btn {
        border: 1px solid #dbd6d0;
        border-radius: var(--ck-radius);
        background: #fdfbf9;
        color: #444;
        font-weight: 700;
        padding: 0.3rem 0.8rem;
        cursor: pointer;
    }

    @@media (max-width: 900px) {
        .recipe-main,
        .recipe-sections {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="recipe-page">
    <section class="recipe-main">
        <div>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.Title" class="recipe-photo" />
            }
            else
            {
                <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=800&h=500&fit=crop" alt="Recipe image" class="recipe-photo" />
            }
        </div>

        <div>
            <div class="recipe-title-row">
                <h1>@Model.Title</h1>
                <div class="recipe-owner-actions">
                     @if (User.Identity?.IsAuthenticated == true && (User.GetUserId() == Model.AuthorId || User.IsInRole("Admin")) && !Model.IsExternal)     {
                        <a asp-controller="Recipe" asp-action="Edit" asp-route-id="@Model.Id" class="recipe-save" title="Edit recipe">
                            Редагувати
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true && User.GetUserId() != Model.AuthorId && !Model.IsExternal)
                    {
                        <a asp-controller="Recipe" asp-action="Report" asp-route-id="@Model.Id" class="recipe-save recipe-report-btn">Скаржитися</a>
                    }
                </div>
            </div>

            <div class="recipe-meta">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="recipe-meta-icon">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                    </svg>
                    @Model.PrepTimeMin хв
                </span>
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="recipe-meta-icon">
                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.64 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                    @Model.Servings порції
                </span>
            </div>

            <div class="recipe-author-row">
                @if (!string.IsNullOrEmpty(Model.AuthorProfilePicturePath))
                {
                    <img src="@Model.AuthorProfilePicturePath" alt="@Model.AuthorName" class="recipe-author-avatar recipe-author-avatar--image" />
                }
                else
                {
                    <span class="recipe-author-avatar">@(Model.AuthorName.Length > 0 ? Model.AuthorName.Substring(0, 1).ToUpper() : "U")</span>
                }
                <a asp-controller="User" asp-action="Profile" asp-route-id="@Model.AuthorId" class="recipe-author-link">@($"@{Model.AuthorName}")</a>

                @if (User.Identity?.IsAuthenticated == true && User.GetUserId() != Model.AuthorId && !Model.IsExternal)
                {
                    if (Model.IsSubscribedToAuthor)
                    {
                        <form asp-controller="User" asp-action="Unsubscribe" asp-route-id="@Model.AuthorId" method="post" class="d-inline">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="recipe-follow recipe-follow--unsubscribe">Відписатись</button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="User" asp-action="Subscribe" asp-route-id="@Model.AuthorId" method="post" class="d-inline">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="recipe-follow">Підписатись</button>
                        </form>
                    }
                }
            </div>

            <div class="recipe-rating-panel">
                <div class="recipe-rating-summary">
                    <span class="recipe-rating-score">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        @Model.AverageRating.ToString("0.0")
                    </span>
                    <span class="recipe-rating-count">(@Model.RatingCount оцінок)</span>
                    @if (Model.CurrentUserRating.HasValue)
                    {
                        <span class="recipe-rating-current">Ваша оцінка: @Model.CurrentUserRating</span>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true && !Model.IsExternal)
                {
                    <form asp-controller="Recipe" asp-action="Rate" asp-route-id="@Model.Id" method="post" class="recipe-rate-form">
                        <span class="recipe-rate-label">Оцініть рецепт:</span>
                        <div class="recipe-rate-stars">
                            @for (var score = 1; score <= 5; score++)
                            {
                                var isActive = Model.CurrentUserRating.HasValue && Model.CurrentUserRating.Value >= score;
                                <button type="submit" name="score" value="@score" class="recipe-rate-star @(isActive ? "recipe-rate-star--active" : string.Empty)" aria-label="Поставити @score зірок" title="@score зірок">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="@(isActive ? "recipe-rate-star-icon--active" : string.Empty)">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                    </svg>
                                </button>
                            }
                        </div>
                    </form>
                }
                else if (!Model.IsExternal)
                {
                    <div class="recipe-rate-note">Увійдіть, щоб поставити оцінку.</div>
                }
            </div>

            <p class="recipe-desc">@Model.Description</p>
        </div>
    </section>

    <section class="recipe-sections">
        <div>
            <h2>
                Інградієнти
            </h2>
            <ul class="ingredients-list">
                @foreach (var ingredient in string.IsNullOrWhiteSpace(Model.Ingredients) ? Array.Empty<string>() : Model.Ingredients.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <li><input type="checkbox" /> @ingredient</li>
                }
            </ul>
        </div>

        <div>
            <h2>
                Спосіб приготування
            </h2>
            <ol class="steps-list">
                @foreach (var step in string.IsNullOrWhiteSpace(Model.CookingMethod) ? Array.Empty<string>() : Model.CookingMethod.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <li>@step</li>
                }
            </ol>
        </div>
    </section>

    <section class="recipe-comments">
        <h2 class="recipe-comments-title">
            Коментарі
        </h2>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" style="color: red; margin-bottom: 1rem;">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (User.Identity?.IsAuthenticated == true && !Model.IsExternal)
        {
            <form asp-controller="Comment" asp-action="Create" method="post" class="comment-form">
                <input type="hidden" name="RecipeId" value="@Model.Id" />
                <input type="text" name="Content" placeholder="Поділіться з іншими як вам смакувало..." required />
                <button type="submit" title="Send comment">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 18px; height: 18px; display: inline; margin-right: 0.3rem;">
                        <path d="M16.6915026,12.4744748 L3.50612381,13.2599618 C3.19218622,13.2599618 3.03521743,13.4170592 3.03521743,13.5741566 L1.15159189,20.0151496 C0.8376543,20.8006365 0.99,21.89 1.77946707,22.52 C2.41,22.99 3.50612381,23.1 4.13399899,22.8429026 L21.714504,14.0454487 C22.6563168,13.5741566 23.1272231,12.6315722 22.9702544,11.6889879 L4.13399899,1.16346272 C3.34915502,0.9 2.40734225,1.00636533 1.77946707,1.4776575 C0.994623095,2.10604706 0.837654326,3.0486314 1.15159189,3.99701575 L3.03521743,10.4380088 C3.03521743,10.5951061 3.34915502,10.7521035 3.50612381,10.7521035 L16.6915026,11.5375905 C16.6915026,11.5375905 17.1624089,11.5375905 17.1624089,12.0088827 C17.1624089,12.4744748 16.6915026,12.4744748 16.6915026,12.4744748 Z"/>
                    </svg>
                    Надіслати
                </button>
            </form>
        }
        else if (!Model.IsExternal)
        {
            <p><a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">Увійдіть</a>, щоб залишити коментар.</p>
        }

        <div class="comments-list">
            @if (Model.Comments != null && Model.Comments.Any())
            {
                foreach (var comment in Model.Comments)
                {
                    <div class="comment-item">
                        <div class="comment-header">
                            <span class="comment-author">@comment.AuthorName</span>
                            <span style="display: inline-flex; align-items: center; gap: 0.6rem;">
                                <span class="comment-date">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                @if (User.Identity?.IsAuthenticated == true && User.GetUserId() == comment.AuthorId)
                                {
                                    <button type="button" class="comment-edit-btn" onclick="toggleEditComment(@comment.Id)" title="Редагувати коментар">✎</button>
                                    <form asp-controller="Comment" asp-action="Delete" method="post" style="margin: 0;">
                                        <input type="hidden" name="id" value="@comment.Id" />
                                        <input type="hidden" name="recipeId" value="@Model.Id" />
                                        <button type="submit" class="comment-delete" title="Видалити коментар">✕</button>
                                    </form>
                                }
                            </span>
                        </div>
                        <div id="comment-content-@comment.Id">
                            <p class="comment-content">@comment.Content</p>
                        </div>

                        <div class="comment-footer">
                            @if (User.Identity?.IsAuthenticated == true && !Model.IsExternal)
                            {
                                <form asp-controller="Comment" asp-action="ToggleLike" method="post" class="comment-like-form">
                                    <input type="hidden" name="id" value="@comment.Id" />
                                    <input type="hidden" name="recipeId" value="@Model.Id" />
                                    <button type="submit" class="comment-like @(comment.IsLikedByCurrentUser ? "comment-like--active" : string.Empty)" title="Лайкнути коментар">
                                        <span aria-hidden="true">♥</span>
                                        <span>@comment.LikesCount</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="comment-like" disabled title="Увійдіть, щоб лайкнути коментар">
                                    <span aria-hidden="true">♥</span>
                                    <span>@comment.LikesCount</span>
                                </button>
                            }
                        </div>

                        @if (User.Identity?.IsAuthenticated == true && User.GetUserId() == comment.AuthorId)
                        {
                            <form asp-controller="Comment" asp-action="Edit" method="post" style="display: none;" id="edit-form-@comment.Id">
                                <input type="hidden" name="Id" value="@comment.Id" />
                                <input type="hidden" name="RecipeId" value="@Model.Id" />
                                <textarea name="Content" required class="comment-edit-input">@comment.Content</textarea>
                                <div class="comment-edit-actions">
                                    <button type="button" class="comment-cancel-btn" onclick="toggleEditComment(@comment.Id)">Скасувати</button>
                                    <button type="submit" class="comment-save-btn">Зберегти</button>
                                </div>
                            </form>
                        }
                    </div>
                }
            }
            else
            {
                <p style="color: #666; margin-top: 1rem;">Коментарів поки немає. Будьте першим!</p>
            }
        </div>
    </section>
</div>

<script>
    function toggleEditComment(commentId) {
        var contentDiv = document.getElementById('comment-content-' + commentId);
        var formDiv = document.getElementById('edit-form-' + commentId);

        if (contentDiv && formDiv) {
            if (contentDiv.style.display === 'none') {
                contentDiv.style.display = 'block';
                formDiv.style.display = 'none';
            } else {
                contentDiv.style.display = 'none';
                formDiv.style.display = 'block';
            }
        }
    }
</script>
