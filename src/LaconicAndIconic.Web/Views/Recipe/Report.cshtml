@model LaconicAndIconic.Web.Models.ReportRecipeViewModel

@{
    ViewData["Title"] = "Скарга на рецепт";
}

<style>
    .report-page {
        max-width: 620px;
        margin: 0 auto;
        padding: 1rem;
    }

    .report-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .report-form .form-group {
        width: 100%;
    }

    .report-form input[readonly],
    .report-form textarea {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }

    .report-form textarea {
        min-height: 140px;
        max-width: 100%;
    }

    .report-actions {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
    }
</style>

<div class="report-page">
    <h1>Скарга на рецепт</h1>

    <form asp-action="Report" method="post" class="report-form">
        @Html.AntiForgeryToken()
        <input asp-for="RecipeId" type="hidden" />
        <input asp-for="ReportedUserId" type="hidden" />

    <div class="form-group">
        <label asp-for="ReportedUserName"></label>
        <input asp-for="ReportedUserName" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="Reason"></label>
        <textarea asp-for="Reason" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Reason" class="text-danger"></span>
    </div>

    <div class="report-actions">
        <button type="submit" class="ck-btn">Надіслати скаргу</button>
        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@Model.RecipeId" class="ck-btn ck-btn--secondary">Скасувати</a>
    </div>
</form>
</div>
