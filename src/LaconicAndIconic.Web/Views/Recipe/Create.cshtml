@model LaconicAndIconic.BLL.Models.CreateRecipeDto
@{
    ViewData["Title"] = "Додати новий рецепт";
}

<div class="recipe-create-container">
    <div class="recipe-create-card">
        <h2 class="recipe-create-title">@ViewData["Title"]</h2>

        <form asp-controller="Recipe" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="recipe-form-grid">
                <div class="recipe-form-group full-width">
                    <label asp-for="Title" class="recipe-label">Назва</label>
                    <input asp-for="Title" class="recipe-input" placeholder="Наприклад: Сирники з малиновим джемом" required />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="recipe-form-group full-width">
                    <label asp-for="Description" class="recipe-label">Опис</label>
                    <textarea asp-for="Description" class="recipe-input" placeholder="Розкажіть трохи про цей рецепт..." required></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="recipe-form-group full-width">
                    <label asp-for="Ingredients" class="recipe-label">Інгредієнти</label>
                    <textarea asp-for="Ingredients" class="recipe-input" placeholder="Кожен інгредієнт з нового рядка" required></textarea>
                    <span asp-validation-for="Ingredients" class="text-danger"></span>
                </div>

                <div class="recipe-form-group full-width">
                    <label asp-for="CookingMethod" class="recipe-label">Спосіб приготування</label>
                    <textarea asp-for="CookingMethod" class="recipe-input" placeholder="Опишіть покроково процес приготування" required></textarea>
                    <span asp-validation-for="CookingMethod" class="text-danger"></span>
                </div>

                <div class="recipe-form-group">
                    <label asp-for="PrepTimeMin" class="recipe-label">Час приготування (хвилин)</label>
                    <input asp-for="PrepTimeMin" class="recipe-input" type="number" min="1" placeholder="45" required />
                    <span asp-validation-for="PrepTimeMin" class="text-danger"></span>
                </div>

                <div class="recipe-form-group">
                    <label asp-for="Servings" class="recipe-label">Кількість порцій</label>
                    <input asp-for="Servings" class="recipe-input" type="number" min="1" placeholder="4" required />
                    <span asp-validation-for="Servings" class="text-danger"></span>
                </div>

                <div class="recipe-form-group">
                    <label asp-for="CategoryId" class="recipe-label">Категорія</label>
                    <select asp-for="CategoryId" class="recipe-input" required>
                        <option value="">-- Оберіть категорію --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="recipe-form-group full-width">
                    <label asp-for="Image" class="recipe-label">Фото страви (опціонально)</label>
                    <div class="file-upload-wrapper">
                        <input asp-for="Image" type="file" accept="image/*" id="recipeImageInput" />
                        <div class="file-upload-text" id="fileUploadText">
                            <span class="file-upload-icon">📷</span>
                            <span>Додайте фотографію вашого кулінарного шедевру</span>
                            <span class="file-upload-hint">Натисніть або перетягніть файл сюди</span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="ck-btn recipe-submit-btn">Готово! Створити рецепт</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('recipeImageInput').addEventListener('change', function(e) {
        var fileName = e.target.files[0] ? e.target.files[0].name : null;
        var textContainer = document.getElementById('fileUploadText');
        if (fileName) {
            textContainer.innerHTML = '<span class="file-upload-icon">✅</span><span>' + fileName + '</span>';
        } else {
            textContainer.innerHTML = '<span class="file-upload-icon">📷</span><span>Додайте фотографію вашого кулінарного шедевру</span><span class="file-upload-hint">Натисніть або перетягніть файл сюди</span>';
        }
    });
</script>
