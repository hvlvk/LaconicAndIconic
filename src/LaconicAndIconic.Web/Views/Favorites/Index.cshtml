@using LaconicAndIconic.BLL.Models
@model IEnumerable<RecipeDto>
@{
    ViewData["Title"] = "My Favorites";
}

<div class="recipe-grid">
    @if (!Model.Any())
    {
        <p style="text-align: center; grid-column: 1 / -1; margin-top: 2rem; color: #888;">You haven't saved any recipes yet.</p>
    }
    else
    {
        @foreach (var recipe in Model)
        {
            <div class="recipe-card">
                <div class="recipe-image">
                    @if (!string.IsNullOrEmpty(recipe.ImagePath))
                    {
                        <img src="@recipe.ImagePath" alt="@recipe.Title">
                    }
                    else
                    {
                        <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=300&h=200&fit=crop" alt="Placeholder">
                    }
                </div>
                <div class="recipe-details">
                    <h3 class="recipe-title">
                        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id">@recipe.Title</a>
                    </h3>
                    <div class="recipe-meta">
                        <span class="recipe-author">@($"@{recipe.AuthorName}")</span>
                    </div>
                    <form method="post" asp-controller="Favorites" asp-action="Remove">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="recipeId" value="@recipe.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </div>
            </div>
        }
    }
</div>
