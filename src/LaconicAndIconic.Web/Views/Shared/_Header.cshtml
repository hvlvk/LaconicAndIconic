<header class="ck-header">
    <a asp-controller="Home" asp-action="Index" class="ck-brand">Cookit</a>

    <form asp-controller="Home" asp-action="Index" method="get" class="ck-search ck-search--bar ck-search--fullwidth">
        <div class="ck-search__input-wrap ck-search__input-wrap--wide">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                 <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="text" name="searchTerm" placeholder="Знайти рецепт..." value="@Context.Request.Query["searchTerm"]"/>
        </div>

        <select name="categoryId" class="ck-select" onchange="this.form.submit()">
            <option value="">Усі категорії</option>
            @if (ViewBag.Categories is not null)
            {
                @foreach (var category in ViewBag.Categories)
                {
                    bool isSelected = Context.Request.Query["categoryId"] == category.Id.ToString();
                    <option value="@category.Id" selected="@(isSelected ? "selected" : null)">@category.Name</option>
                }
            }
        </select>

        <select name="sortBy" class="ck-select" onchange="this.form.submit()">
            @{
                string currentSort = Context.Request.Query["sortBy"].ToString();
            }
            <option value="" selected="@(string.IsNullOrEmpty(currentSort) ? "selected" : null)">Найновіші</option>
            <option value="title_asc" selected="@(currentSort == "title_asc" ? "selected" : null)">Назва (А-Я)</option>
            <option value="title_desc" selected="@(currentSort == "title_desc" ? "selected" : null)">Назва (Я-А)</option>
            <option value="prepTime_asc" selected="@(currentSort == "prepTime_asc" ? "selected" : null)">Час приготування (↑)</option>
            <option value="prepTime_desc" selected="@(currentSort == "prepTime_desc" ? "selected" : null)">Час приготування (↓)</option>
        </select>

        <button type="submit" class="ck-btn ck-btn-sm">
            Пошук
        </button>
    </form>

    <div class="ck-header-icons">
        @if (User.Identity is { IsAuthenticated: true })
        {
            <a href="#" class="ck-heart-active" title="Обране">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="currentColor" stroke="currentColor" stroke-width="1">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
            </a>
            <a href="#" title="Сповіщення">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </a>
            <a asp-controller="SharedList" asp-action="Index" title="Спільні списки">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
                    <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                </svg>
            </a>
            <a asp-controller="User" asp-action="Profile" asp-route-id="@User.GetUserId()" title="Профіль">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/>
                </svg>
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="ck-logout-form">
                <button type="submit" title="Вийти">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </button>
            </form>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="ck-btn ck-btn-sm">Увійти</a>
        }
    </div>
</header>
