<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Cookit</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/main.bundle.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/LaconicAndIconic.Web.styles.css" asp-append-version="true"/>
</head>
<body>
    <partial name="_Header"/>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="notificationHost" class="notification-host" aria-live="polite" aria-atomic="true"></div>
    }
    <div class="container">
        <main role="main" class="pb-3 pt-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/lib/signalr/signalr.min.js"></script>
    }
    <script src="~/js/site.bundle.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
